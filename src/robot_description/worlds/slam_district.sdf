    <model name="z4_but2"><static>true</static><pose>  0 -133 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>3 2 3.5</size></box></geometry><pose>0 0 1.75 0 0 0</pose></collision><visual name="vis"><geometry><box><size>3 2 3.5</size></box></geometry><pose>0 0 1.75 0 0 0</pose><material><ambient>0.5 0.5 0.45 1</ambient><diffuse>0.5 0.5 0.45 1</diffuse></material></visual></link></model>
    <model name="z4_but3"><static>true</static><pose> 25 -133 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>3 2 3.5</size></box></geometry><pose>0 0 1.75 0 0 0</pose></collision><visual name="vis"><geometry><box><size>3 2 3.5</size></box></geometry><pose>0 0 1.75 0 0 0</pose><material><ambient>0.5 0.5 0.45 1</ambient><diffuse>0.5 0.5 0.45 1</diffuse></material></visual></link></model>

    <!-- ================================================================
         ZONE 5 — SCULPTURAL PARK   x ∈ [-130, -30]   y ∈ [-30, 30]
         Three geometrically unique sculptures + perimeter tree ring.
         Sparse features test scan matcher under low-return conditions.
         ================================================================ -->

    <!-- Sculpture A: Monolith — 1×1×8 m.  Tallest thin structure anywhere. -->
    <model name="monolith">
      <static>true</static>
      <pose>-90 10 0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>1 1 8</size></box></geometry><pose>0 0 4 0 0 0</pose></collision>
        <visual   name="vis"><geometry><box><size>1 1 8</size></box></geometry><pose>0 0 4 0 0 0</pose>
          <material><ambient>0.55 0.55 0.62 1</ambient><diffuse>0.55 0.55 0.62 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Sculpture B: Arch — two posts + crossbar spanning 6 m in Y. -->
    <model name="arch_post_l"><static>true</static><pose>-115 23 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>0.6 0.6 5</size></box></geometry><pose>0 0 2.5 0 0 0</pose></collision><visual name="vis"><geometry><box><size>0.6 0.6 5</size></box></geometry><pose>0 0 2.5 0 0 0</pose><material><ambient>0.50 0.50 0.58 1</ambient><diffuse>0.50 0.50 0.58 1</diffuse></material></visual></link></model>
