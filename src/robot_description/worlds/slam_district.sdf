    <model name="house_c2r0"><static>true</static><pose> 20  -75 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose></collision><visual name="vis"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose><material><ambient>0.85 0.78 0.65 1</ambient><diffuse>0.85 0.78 0.65 1</diffuse></material></visual></link></model>
    <model name="house_c0r1"><static>true</static><pose>-20  -97 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose></collision><visual name="vis"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose><material><ambient>0.85 0.78 0.65 1</ambient><diffuse>0.85 0.78 0.65 1</diffuse></material></visual></link></model>
    <model name="house_c1r1"><static>true</static><pose>  0  -97 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose></collision><visual name="vis"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose><material><ambient>0.85 0.78 0.65 1</ambient><diffuse>0.85 0.78 0.65 1</diffuse></material></visual></link></model>
    <model name="house_c2r1"><static>true</static><pose> 20  -97 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose></collision><visual name="vis"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose><material><ambient>0.85 0.78 0.65 1</ambient><diffuse>0.85 0.78 0.65 1</diffuse></material></visual></link></model>
    <model name="house_c0r2"><static>true</static><pose>-20 -119 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose></collision><visual name="vis"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose><material><ambient>0.85 0.78 0.65 1</ambient><diffuse>0.85 0.78 0.65 1</diffuse></material></visual></link></model>
    <model name="house_c1r2"><static>true</static><pose>  0 -119 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose></collision><visual name="vis"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose><material><ambient>0.85 0.78 0.65 1</ambient><diffuse>0.85 0.78 0.65 1</diffuse></material></visual></link></model>
    <model name="house_c2r2"><static>true</static><pose> 20 -119 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose></collision><visual name="vis"><geometry><box><size>10 8 3</size></box></geometry><pose>0 0 1.5 0 0 0</pose><material><ambient>0.85 0.78 0.65 1</ambient><diffuse>0.85 0.78 0.65 1</diffuse></material></visual></link></model>

    <!-- Deviant house (c0r0): extra south-face parapet visible at close range -->
    <model name="house_c0r0_parapet">
      <static>true</static>
      <pose>-20 -79.2 0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>10 0.4 1.5</size></box></geometry><pose>0 0 3.75 0 0 0</pose></collision>
        <visual   name="vis"><geometry><box><size>10 0.4 1.5</size></box></geometry><pose>0 0 3.75 0 0 0</pose>
          <material><ambient>0.75 0.68 0.55 1</ambient><diffuse>0.75 0.68 0.55 1</diffuse></material></visual>
      </link>
    </model>

    <!-- South perimeter wall with buttresses — unique zone boundary -->
    <model name="z4_south_wall">
      <static>true</static>
      <pose>0 -132 0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>70 0.6 2</size></box></geometry><pose>0 0 1 0 0 0</pose></collision>
