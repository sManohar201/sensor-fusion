    <model name="arch_bar"><static>true</static><pose>-115 20 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>0.6 7 0.6</size></box></geometry><pose>0 0 5.1 0 0 0</pose></collision><visual name="vis"><geometry><box><size>0.6 7 0.6</size></box></geometry><pose>0 0 5.1 0 0 0</pose><material><ambient>0.50 0.50 0.58 1</ambient><diffuse>0.50 0.50 0.58 1</diffuse></material></visual></link></model>

    <!-- Sculpture C: Wedge stack — 3 offset slabs, unique staircase in 3D scan. -->
    <model name="wedge_1"><static>true</static><pose>-105 -20 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>4 1 0.5</size></box></geometry><pose>0 0 0.25 0 0 0</pose></collision><visual name="vis"><geometry><box><size>4 1 0.5</size></box></geometry><pose>0 0 0.25 0 0 0</pose><material><ambient>0.50 0.50 0.58 1</ambient><diffuse>0.50 0.50 0.58 1</diffuse></material></visual></link></model>
    <model name="wedge_2"><static>true</static><pose>-104 -20 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>4 1 0.5</size></box></geometry><pose>0 0 1.25 0 0 0</pose></collision><visual name="vis"><geometry><box><size>4 1 0.5</size></box></geometry><pose>0 0 1.25 0 0 0</pose><material><ambient>0.50 0.50 0.58 1</ambient><diffuse>0.50 0.50 0.58 1</diffuse></material></visual></link></model>
    <model name="wedge_3"><static>true</static><pose>-103 -20 0 0 0 0</pose><link name="link"><collision name="col"><geometry><box><size>4 1 0.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision><visual name="vis"><geometry><box><size>4 1 0.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose><material><ambient>0.50 0.50 0.58 1</ambient><diffuse>0.50 0.50 0.58 1</diffuse></material></visual></link></model>

    <!-- Long low wall — 30 m, triggers brief corridor problem at y=-26 -->
    <model name="z5_low_wall">
      <static>true</static>
      <pose>-100 -26 0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>30 0.4 1.2</size></box></geometry><pose>0 0 0.6 0 0 0</pose></collision>
